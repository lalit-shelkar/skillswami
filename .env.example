# =============================================================================
# Skillswami — environment variables
# Copy to .env locally. Add the same keys in Vercel → Settings → Environment Variables.
# =============================================================================

# Neon Postgres (Dashboard → Connect)
# DATABASE_URL = pooled connection (hostname includes "-pooler") — used by the app on Vercel
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL = direct connection (no "-pooler") — used for prisma db push / migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Auth — use a long random string in production (openssl rand -base64 32)
JWT_SECRET="replace-with-a-long-random-string"

# Public site URL — must match your Vercel domain (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cashfree (sandbox for testing, production when live)
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="sandbox"

# 1 coin = 1 INR by default
COINS_PER_RUPEE="1"

# =============================================================================
# Before first Vercel deploy (run locally once with Neon URLs in .env):
#   npm run db:push
#   npm run db:seed
#
# Cashfree webhook (production): https://YOUR_DOMAIN/api/payments/webhook
# =============================================================================
